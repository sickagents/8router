# 8Router Configuration Example
# Copy this file to .env and fill in your values

# Server Configuration
PORT=20127
HOSTNAME=0.0.0.0
NEXT_PUBLIC_BASE_URL=http://localhost:20127

# Environment
NODE_ENV=production

# Authentication
# Set initial admin password (default: 123456)
INITIAL_PASSWORD=your_secure_password_here

# Database
# SQLite database file path (relative to project root)
DATABASE_PATH=./data/8router.db

# Logging
# Enable request/response logging to logs/ directory
ENABLE_REQUEST_LOGS=true

# Optional: OAuth Provider Credentials
# Replace placeholders in code with these values

# Google OAuth (for Google AI Studio, Gemini)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth (for GitHub Copilot)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OpenAI (if using direct API)
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic (if using direct API)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Optional: Rate Limiting
# Requests per minute per API key
RATE_LIMIT_PER_MINUTE=60

# Optional: Token Compression
# Enable RTK token compression (default: true)
ENABLE_RTK_COMPRESSION=true

# Optional: CORS
# Comma-separated list of allowed origins (default: *)
CORS_ORIGINS=*

# Optional: Database Backup
# Enable automatic daily database backup
ENABLE_DB_BACKUP=false
DB_BACKUP_PATH=./backups

# Optional: Metrics
# Enable Prometheus metrics endpoint at /metrics
ENABLE_METRICS=false

# Optional: Session
# Session secret for JWT tokens (auto-generated if not set)
SESSION_SECRET=your_random_session_secret_here
